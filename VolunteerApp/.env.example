# Volunteer App - Environment Configuration

# API Base URL
# Change these to match your backend server
API_BASE_URL=http://10.0.2.2:8000/api
# For physical device, use your computer's local IP:
# API_BASE_URL=http://192.168.1.x:8000/api

# Google OAuth (configure in Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# App settings
APP_NAME=Volunteer App
APP_VERSION=1.0.0

# Feature flags
ENABLE_TRUST_EVAL=true
ENABLE_AI_SUGGESTIONS=true
